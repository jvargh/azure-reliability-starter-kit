      "name": "checkoutavailabilityslitrend"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "{\"type\":\"query_range\",\"version\":\"PrometheusQueryProvider/1.0\",\"queryText\":\"label_replace(clamp_max(100 * sum(sli:dependency_calls:rate5m{dependency=\\\"payment\\\",status=\\\"ok\\\"}) / sum(sli:dependency_calls:rate5m{dependency=\\\"payment\\\"}), 100), \\\"series\\\", \\\"payment_dependency\\\", \\\"\\\", \\\"\\\")\"}",
